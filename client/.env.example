# Environment Variables for LMS Frontend

# API Base URL - Points to the backend server
NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: allow exposing admin signup in local development
# The backend only permits the first admin account by default.
NEXT_PUBLIC_ENABLE_ADMIN_SIGNUP=true

# Note: The backend should be running on this URL.
# The frontend client can also try localhost:5001 in local development
# if you intentionally move the backend off port 5000.
# For production, update to your production API URL
# Example: NEXT_PUBLIC_API_URL=https://api.tutorlabs.com
